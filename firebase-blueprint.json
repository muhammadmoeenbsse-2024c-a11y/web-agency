{
  "entities": {
    "PortfolioItem": {
      "title": "Portfolio Item",
      "description": "A project showcased in the portfolio section.",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "The name of the project." },
        "description": { "type": "string", "description": "Brief overview of the project." },
        "imageUrl": { "type": "string", "format": "uri", "description": "URL to the project's thumbnail image." },
        "link": { "type": "string", "format": "uri", "description": "Link to the live website." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Timestamp of creation." }
      },
      "required": ["title", "imageUrl", "createdAt"]
    },
    "ContactSubmission": {
      "title": "Contact Submission",
      "description": "Information submitted via the contact form.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Name of the person contacting." },
        "email": { "type": "string", "format": "email", "description": "Email address of the person." },
        "message": { "type": "string", "description": "The message content." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Timestamp of submission." }
      },
      "required": ["name", "email", "message", "createdAt"]
    }
  },
  "firestore": {
    "/portfolio/{itemId}": {
      "schema": "PortfolioItem",
      "description": "Collection of portfolio projects."
    },
    "/contacts/{contactId}": {
      "schema": "ContactSubmission",
      "description": "Collection of contact form submissions."
    }
  }
}
